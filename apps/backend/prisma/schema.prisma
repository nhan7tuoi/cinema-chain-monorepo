generator client {
  provider     = "prisma-client-js"
  output       = "../../node_modules/.prisma/generated"
  moduleFormat = "commonjs"
}

datasource db {
  provider = "postgresql"
}

// =========================================================================
// 1. PHÂN HỆ AUTHENTICATION & DANH TÍNH (USER, CUSTOMER, EMPLOYEE)
// =========================================================================

enum UserType {
  CUSTOMER
  EMPLOYEE
  MANAGER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  LOCKED
  HIDDEN
}

model User {
  id        String     @id @default(uuid())
  email     String?    @unique // Cho phép null để khách hàng đăng ký thuần bằng SĐT
  phone     String?    @unique // SĐT định danh đăng nhập chính (Hệ thống tổng)
  password  String
  userType  UserType   @default(CUSTOMER) // Loại tài khoản cao nhất hoặc mặc định
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Mối quan hệ 1:1 song song. Một User có thể đồng thời có cả profile Customer và Employee
  customer Customer?
  employee Employee?

  @@map("users")
}

model Customer {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName  String
  avatarUrl String?   @db.Text
  points    Int       @default(0)
  rank      String    @default("MEMBER") // MEMBER, VIP, VVIP
  birthDate DateTime?
  slug      String?   @db.VarChar(255)

  @@map("customers")
}

model Employee {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName  String
  avatarUrl String? @db.Text
  code      String  @unique // Mã nhân viên nội bộ (Ví dụ: NV001, NV002...)
  slug      String? @db.VarChar(255)

  // Địa bàn làm việc của nhân viên tại cơ sở
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // Vai trò của nhân viên trong hệ thống (Dynamic RBAC)
  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@map("employees")
}

// =========================================================================
// 2. PHÂN HỆ PHÂN QUYỀN ĐỘNG (DYNAMIC RBAC MATRIX)
// =========================================================================

model Role {
  id          String   @id @default(uuid())
  code        String   @unique // Mã định danh hệ thống viết hoa (Ví dụ: "BRANCH_MANAGER")
  name        String // Tên hiển thị tiếng Việt (Ví dụ: "Quản Lý Chi Nhánh")
  description String?
  isSystem    Boolean  @default(false) // Chặn xóa nhầm các role cấu hình cứng hệ thống
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  employees   Employee[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  name        String  @unique // Cấu trúc dạng "module:action" (Ví dụ: "movie:create")
  displayName String // Nhãn tiếng Việt để render lên FE (Ví dụ: "Thêm phim mới")
  module      String // Nhóm cha (Ví dụ: "Quản Lý Phim")
  description String?

  roles RolePermission[]

  @@map("permissions")
}

// Bảng trung gian kết nối Nhóm quyền <-> Quyền chi tiết
model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// =========================================================================
// 3. PHÂN HỆ CƠ SỞ HẠ TẦNG (MASTER DATA)
// =========================================================================

model Branch {
  id        String   @id @default(uuid())
  name      String   @unique
  address   String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]

  @@map("branches")
}

// =========================================================================
// 4. PHÂN HỆ QUẢN LÝ PHIM (MOVIES)
// =========================================================================

enum MovieStatus {
  NOW_SHOWING
  COMING_SOON
  ENDED
}

model Movie {
  id          String      @id @default(uuid())
  title       String
  director    String?
  cast        String?
  genre       String?
  duration    Int // Thời lượng (phút)
  releaseDate DateTime
  endDate     DateTime?
  format      String      @default("2D")
  synopsis    String?     @db.Text
  posterUrl   String?     @db.Text
  trailerUrl  String?     @db.Text
  status      MovieStatus @default(COMING_SOON)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("movies")
}
